{
  "groups": {
    "group:admin": ["simon@ts.example.com"]
  },
  "tagOwners": {
    "tag:app": ["group:admin"]
  },
  "grants": [
    // Everyone can access their own devices
    {
      "src": ["autogroup:member"],
      "dst": ["autogroup:self"],
      "ip": ["*"]
    },
    // Everyone can access apps via HTTPS
    {
      "src": ["*"],
      "dst": ["tag:app:443"],
      "ip": ["*"]
    }
  ]
}
